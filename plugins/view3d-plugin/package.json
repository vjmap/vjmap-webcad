{
  "name": "vcad-plugin-view3d",
  "version": "1.0.0",
  "description": "三维查看插件 - 将WebCAD中带Z值的实体在3D视图中可视化",
  "type": "module",
  "main": "dist/vcad-plugin-view3d.js",
  "module": "dist/vcad-plugin-view3d.js",
  "vjcadPlugin": {
    "id": "view3d",
    "displayName": "三维查看",
    "autoLoad": false,
    "keywords": [
      "view3d",
      "3d",
      "viewer",
      "elevation",
      "z-value"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "webcad",
    "plugin",
    "view3d",
    "3d",
    "visualization"
  ],
  "author": "vjmap",
  "license": "MIT",
  "peerDependencies": {
    "vjcad": ">=1.0.2"
  },
  "dependencies": {
    "vjmap3d": "1.0.23",
    "three": "^0.165.0",
    "vjcad": ">=1.0.2"
  },
  "devDependencies": {
    "@types/three": "^0.165.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
