{
  "name": "vcad-plugin-network-graph",
  "version": "1.0.0",
  "description": "网络图绘制插件 - 支持节点和分支的拓扑网络图绘制",
  "type": "module",
  "main": "dist/vcad-plugin-network-graph.js",
  "module": "dist/vcad-plugin-network-graph.js",
  "vjcadPlugin": {
    "id": "network-graph",
    "displayName": "网络图",
    "autoLoad": false,
    "keywords": [
      "network",
      "graph",
      "topology",
      "node",
      "branch"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "webcad",
    "plugin",
    "network",
    "graph",
    "topology"
  ],
  "author": "vjmap",
  "license": "MIT",
  "peerDependencies": {
    "vjcad": ">=1.0.2"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vjcad": ">=1.0.2"
  }
}
